# Alpaca API credentials (https://app.alpaca.markets/ -> generate keys)
# Paper trading is recommended while building.
ALPACA_API_KEY_ID=your_key_id
ALPACA_API_SECRET_KEY=your_secret_key

# Paper:  https://paper-api.alpaca.markets
# Live:   https://api.alpaca.markets
ALPACA_TRADING_BASE_URL=https://paper-api.alpaca.markets

# Market data (sparklines / latest quotes)
ALPACA_DATA_BASE_URL=https://data.alpaca.markets

# Set to "true" to force mock data even when keys are present
USE_MOCK_DATA=false
